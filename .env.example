# Secure Cloud File Vault environment variables
#
# Copy this file to .env for local development:
#   cp .env.example .env
#
# Do not commit .env. It contains real project keys and secrets.

# Client-visible Supabase values
VITE_SUPABASE_URL="https://YOUR-PROJECT-REF.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="YOUR-PUBLISHABLE-OR-ANON-KEY"
VITE_SUPABASE_PROJECT_ID="YOUR-PROJECT-REF"

# Production auth redirect URL
# Example: https://your-app.workers.dev/auth/callback
VITE_SITE_URL="http://localhost:8080/auth/callback"

# Server-side Supabase values
SUPABASE_URL="https://YOUR-PROJECT-REF.supabase.co"
SUPABASE_PUBLISHABLE_KEY="YOUR-PUBLISHABLE-OR-ANON-KEY"
SUPABASE_PROJECT_ID="YOUR-PROJECT-REF"

# Server-only secret. Never expose this with a VITE_ prefix.
SUPABASE_SERVICE_ROLE_KEY="YOUR-SERVICE-ROLE-KEY"
